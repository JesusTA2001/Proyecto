# Variables de entorno para producción (Vercel)
# Desactivar ESLint como error en build
ESLINT_NO_DEV_ERRORS=true
DISABLE_ESLINT_PLUGIN=true
GENERATE_SOURCEMAP=false

# En Vercel, frontend y backend están en el mismo dominio.
# No es necesario definir REACT_APP_API_URL; el fallback /api se usa automáticamente.
# Si en el futuro el backend está en otro dominio, descomenta y actualiza:
# REACT_APP_API_URL=https://tu-backend.vercel.app/api
